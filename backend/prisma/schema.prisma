generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATASOURCE_URL")
}

// --- ENUMS ---

enum PromoType {
  VIP_DAYS
  BALANCE
}

enum RaceStatus {
  WAITING
  STARTED
  FINISHED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WithdrawalStatus {
  PENDING // Заявка создана, средства заморожены, ждет модератора
  APPROVED // Модератор одобрил, транзакция отправлена в сеть
  REJECTED // Модератор отклонил, средства вернулись на баланс
}

enum VerificationCodeType {
  WEB_LOGIN
  PASSWORD_RESET
  GAME_LOGIN
}

// --- MODELS ---

model User {
  id          Int      @id @default(autoincrement())
  telegram_id BigInt   @unique
  username    String?
  created_at  DateTime @default(now())

  vip_expires_at DateTime?

  balance        Float @default(0.0)
  frozen_balance Float @default(0.0)

  withdrawals WithdrawalRequest[]

  // Авторизация
  connect_code            String?   @unique
  connect_code_expires_at DateTime?

  activated_promos PromoCode[]

  // Связь: один юзер -> много игровых аккаунтов
  game_accounts GameAccount[]

  // Исторически созданные гонки
  created_races Race[]

  settings     UserSettings?
  transactions Transactions[]

  tokens             Tokens[]
  verification_codes VerificationCodes[]
}

model VerificationCodes {
  id Int @id @default(autoincrement())

  user_id    Int
  user       User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  code       String
  type       VerificationCodeType
  expires_at DateTime

  @@index([user_id, code])
}

model UserSettings {
  id Int @id @default(autoincrement())

  user_id Int  @unique
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // --- 🎨 ИНТЕРФЕЙС ---
  language String @default("ru")
  currency String @default("RUB")
  timezone Int    @default(0)

  // --- 🔔 УВЕДОМЛЕНИЯ ---
  notify_news     Boolean @default(true)
  notify_payments Boolean @default(true)

  // --- 🔐 БЕЗОПАСНОСТЬ ---
  is_stealth Boolean @default(false)

  updated_at DateTime @updatedAt
}

model PromoCode {
  id   Int    @id @default(autoincrement())
  code String @unique

  type  PromoType
  value Int

  is_used Boolean   @default(false)
  used_at DateTime?

  user_id Int?
  user    User? @relation(fields: [user_id], references: [id])

  created_at DateTime @default(now())
}

model GameAccount {
  id       Int     @id @default(autoincrement())
  nickname String
  server   Int
  verified Boolean @default(true)
  wins     Int     @default(0)

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  // Связи для гонок
  races_won      Race[]            @relation("RaceWinner")
  participations RaceParticipant[] // Участие в гонках

  // Связи для системы свидетелей (АНТИЧИТ)
  sightings_observed RaceWitness[] @relation("ObserverRelation") // Кого я видел
  sightings_suspect  RaceWitness[] @relation("SuspectRelation") // Кто меня видел

  @@unique([nickname, server])
}

model Location {
  id      Int    @id @default(autoincrement())
  name    String
  file_id String // ID картинки в телеграм

  pos_one_x Float
  pos_one_y Float
  pos_one_z Float

  pos_two_x Float
  pos_two_y Float
  pos_two_z Float

  races Race[]
}

model Race {
  id Int @id @default(autoincrement())

  secret_code String     @unique // Код для входа
  is_vip      Boolean    @default(false)
  status      RaceStatus @default(WAITING)

  location_id Int
  location    Location @relation(fields: [location_id], references: [id])

  // Победитель (быстрый доступ)
  winner_id   Int?
  winner      GameAccount? @relation("RaceWinner", fields: [winner_id], references: [id], onDelete: SetNull)
  winner_path Json? // Полный путь победителя для разбора полетов

  prize    String
  start_at DateTime // Запланированное время старта

  // --- 🔥 ВАЖНО ДЛЯ АНТИЧИТА ---
  server_start_time DateTime? // Реальное время старта на сервере (для таймингов)

  // Связи
  creator_id Int?
  creator    User? @relation(fields: [creator_id], references: [id])

  participants RaceParticipant[] // Все участники и их статус
  witnesses    RaceWitness[] // Логи "кто кого видел"

  created_at DateTime @default(now())
}

// 🛡️ ТАБЛИЦА УЧАСТНИКОВ (Детальная статистика)
model RaceParticipant {
  id Int @id @default(autoincrement())

  race_id Int
  race    Race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  game_account_id Int
  game_account    GameAccount @relation(fields: [game_account_id], references: [id], onDelete: Cascade)

  // Статус финиша
  finished         Boolean   @default(false)
  server_finish_at DateTime? // Время финиша по серверу
  client_time_ms   Int? // Время, которое заявил клиент (для сверки)

  // Античит флаги
  is_disqualified  Boolean @default(false) // Забанен ли в этой гонке
  suspicion_reason String? // "Teleport", "Speedhack", "No Witnesses"

  telemetry RaceTelemetry[] // История позиций этого игрока

  @@unique([race_id, game_account_id]) // Игрок не может быть дважды в одной гонке
}

// 👁️ ТАБЛИЦА СВИДЕТЕЛЕЙ (Witness System)
model RaceWitness {
  id Int @id @default(autoincrement())

  race_id Int
  race    Race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  // Кто видел (Свидетель) — тут лучше оставить по ID, так как мы точно знаем, кто отправляет запрос
  observer_id Int
  observer    GameAccount @relation("ObserverRelation", fields: [observer_id], references: [id], onDelete: Cascade)

  // Кого видели (Подозреваемый)
  suspect_nickname String
  suspect_server   Int // Исправлено: Number -> Int

  // Связь по составному уникальному ключу
  suspect GameAccount @relation("SuspectRelation", fields: [suspect_nickname, suspect_server], references: [nickname, server], onDelete: Cascade)

  server_time DateTime @default(now())

  // Обновленный индекс: ищем по гонке и никнейму подозреваемого
  @@index([race_id, suspect_nickname, suspect_server])
}

// 📈 ТАБЛИЦА ТЕЛЕМЕТРИИ (Физика)
model RaceTelemetry {
  id Int @id @default(autoincrement())

  participant_id Int
  participant    RaceParticipant @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  x     Float
  y     Float
  z     Float
  speed Float

  client_timestamp BigInt // Время Lua (os.clock или timestamp)
  created_at       DateTime @default(now())
}

model Transactions {
  id Int @id @default(autoincrement())

  hash    String? @unique
  user_id Int
  user    User    @relation(fields: [user_id], references: [id]) // Добавил связь

  amount  BigInt
  comment String        @unique
  status  PaymentStatus

  created_at DateTime @default(now()) // Привел к общему стилю snake_case
  updated_at DateTime @updatedAt
}

model WithdrawalRequest {
  id Int @id @default(autoincrement())

  // --- 👤 КТО ВЫВОДИТ ---
  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  // --- 💰 ДЕТАЛИ ---
  amount         Float // Сумма вывода (должна совпадать с типом balance в User)
  currency       String @default("TON") // Валюта (TON, USDT, RUB и т.д.)
  wallet_address String // Реквизиты, куда отправляем деньги (адрес кошелька / карта)

  // --- ⚙️ СТАТУС ---
  status WithdrawalStatus @default(PENDING)

  // --- 👮 МОДЕРАЦИЯ ---
  rejection_reason String? // Если отклонили, пишем причину (для юзера)
  admin_comment    String? // Внутренняя заметка админа (не видна юзеру)

  // --- 🔗 ТЕХНИЧЕСКИЕ ДАННЫЕ ---
  tx_hash      String? // Хэш транзакции в блокчейне (после выплаты)
  processed_at DateTime? // Дата, когда админ обработал заявку

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Tokens {
  id Int @id @default(autoincrement())

  user_id Int  @unique
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  refresh_token String @unique

  created_at DateTime @default(now())
}
