generator client {
  provider = "prisma-client-js"
  output   = "../src/v2/generated"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/v2/generated/zod"
}

datasource db {
  provider = "postgresql"
  url      = env("DATASOURCE_URL")
}

// --- ENUMS ---

enum RaceStatus {
  WAITING
  STARTED
  FINISHED
  CANCELLED
}

enum CarStatus {
  FOR_SALE
  TRADING
  SOLD
  EXPIRED
}

enum CarRarity {
  LEGENDARY
  RARE
  JUNK
}

enum OilStatus {
  GOOD
  MEDIUM
  BAD
}

enum DealStatus {
  PENDING
  BUYER_CONTACTED
  WAITING_FOR_FINISH
  COMPLETED
  CANCELLED
  CLOSED_WITH_PENALTY
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum VerificationCodeType {
  WEB_LOGIN
  PASSWORD_RESET
  GAME_LOGIN
}

enum AuctionStatus {
  CREATED
  OPEN
  FINISHED
  CANCELLED
}

enum SlotType {
  OPEN
  CLOSED
  LUCKY
}

enum RaceType {
  FREE // Бесплатная (код в канал)
  PAID // Платная (код в ЛС победителям аукциона)
}

enum DisqualificationReason {
  NOT_IN_START_ZONE
  CHEATING_SUSPECT
  TELEPORT
  SPEEDHACK
}

// --- MODELS ---

model User {
  id             Int       @id @default(autoincrement())
  telegram_id    BigInt    @unique
  username       String?
  created_at     DateTime  @default(now())
  vip_expires_at DateTime?

  points        BigInt @default(0)
  frozen_points BigInt @default(0)

  balance        BigInt @default(0)
  frozen_balance BigInt @default(0)

  reputation Int @default(100)

  banned_until  DateTime?
  ban_reason    String?
  token_version Int       @default(0)

  // Связи
  game_accounts GameAccount[]
  created_races Race[]        @relation("UserCreatedRaces")
  won_races     Race[]        @relation("RaceWinner") // Связь через GameAccount обычно, но если напрямую — ок
  settings      UserSettings?
  tokens        Tokens[]

  car_listings    CarListing[]
  buyer_deals     CarDeal[]    @relation("BuyerDeals")
  reports_filed   Report[]     @relation("Reporter")
  reports_against Report[]     @relation("Target")

  won_slots    AuctionSlot[]
  auction_bids AuctionBid[]

  race_bets         RaceBet[]
  verificationCodes VerificationCodes?
}

model VerificationCodes {
  id          Int                  @id @default(autoincrement())
  telegram_id BigInt               @unique
  code        String               @unique
  type        VerificationCodeType
  expires_at  DateTime

  user User @relation(fields: [telegram_id], references: [telegram_id])
}

model UserSettings {
  id      Int  @id @default(autoincrement())
  user_id Int  @unique
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  updated_at DateTime @updatedAt
}

model GameAccount {
  id       Int     @id @default(autoincrement())
  game_id  Int
  nickname String
  server   Int
  level    Int
  is_main  Boolean @default(false)

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  received_bets  RaceBet[]
  participations RaceParticipant[]
  car_listings   CarListing[]
  won_race_refs  Race[]            @relation("GameAccountWinner")

  @@unique([game_id, server])
  @@index([user_id])
}

model Location {
  id        Int    @id @default(autoincrement())
  name      String
  file_id   String
  pos_one_x Float
  pos_one_y Float
  pos_one_z Float
  pos_two_x Float
  pos_two_y Float
  pos_two_z Float
  races     Race[]
}

model Race {
  id          Int        @id @default(autoincrement())
  secret_code String     @unique
  status      RaceStatus @default(WAITING)

  location_id Int
  location    Location @relation(fields: [location_id], references: [id])

  // Кто победил (связь с GameAccount)
  winner_id  Int?
  winner_acc GameAccount? @relation("GameAccountWinner", fields: [winner_id], references: [id], onDelete: SetNull)

  // Кто победил (связь с User для истории)
  winner_user_id Int?
  winner_user    User? @relation("RaceWinner", fields: [winner_user_id], references: [id])

  winner_path Json?
  prize       String
  start_at    DateTime

  creator_id Int?
  creator    User? @relation("UserCreatedRaces", fields: [creator_id], references: [id])

  race_bets RaceBet[]

  participants RaceParticipant[]
  auction      Auction?
  created_at   DateTime          @default(now())
}

model RaceParticipant {
  id      Int  @id @default(autoincrement())
  race_id Int
  race    Race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  is_disqualified Boolean                 @default(false)
  disqualified_at DateTime?
  dq_reason       DisqualificationReason?

  game_account_id Int
  game_account    GameAccount @relation(fields: [game_account_id], references: [id], onDelete: Cascade)

  finished         Boolean        @default(false)
  server_finish_at DateTime?
  telemetry        RaceTelemetry?

  @@unique([race_id, game_account_id])
}

model RaceTelemetry {
  id             Int             @id @default(autoincrement())
  participant_id Int             @unique
  participant    RaceParticipant @relation(fields: [participant_id], references: [id], onDelete: Cascade)

  raw_path   Json?
  speed      Float
  created_at DateTime @default(now())
}

model Tokens {
  id            Int      @id @default(autoincrement())
  user_id       Int      @unique
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  refresh_token String   @unique
  created_at    DateTime @default(now())
}

// --- АВТОБАЗАР ---

model CarListing {
  id         Int         @id @default(autoincrement())
  seller_id  Int
  seller     User        @relation(fields: [seller_id], references: [id], onDelete: Cascade)
  account_id Int
  account    GameAccount @relation(fields: [account_id], references: [id])

  model_id   Int
  model_name String
  price      BigInt

  rarity       CarRarity @default(JUNK)
  rarity_num   Int
  plate_number String?
  mileage      Float     @default(0.0)
  oil_status   OilStatus @default(GOOD)
  condition    Int       @default(100)
  has_launch   Boolean   @default(false)
  description  String?
  image_id     String?

  is_negotiable Boolean   @default(false)
  is_vice_city  Boolean   @default(false)
  status        CarStatus @default(FOR_SALE)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deal       CarDeal?

  @@index([rarity, rarity_num])
}

model CarDeal {
  id         Int        @id @default(autoincrement())
  listing_id Int        @unique
  listing    CarListing @relation(fields: [listing_id], references: [id], onDelete: Cascade)

  buyer_id Int
  buyer    User @relation("BuyerDeals", fields: [buyer_id], references: [id])

  seller_notified_contact Boolean @default(false)
  buyer_notified_contact  Boolean @default(false)
  seller_confirmed_deal   Boolean @default(false)
  buyer_confirmed_deal    Boolean @default(false)

  status           DealStatus @default(PENDING)
  contact_deadline DateTime
  deal_deadline    DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Report {
  id          Int          @id @default(autoincrement())
  reporter_id Int
  reporter    User         @relation("Reporter", fields: [reporter_id], references: [id])
  target_id   Int
  target      User         @relation("Target", fields: [target_id], references: [id])
  deal_id     Int?
  reason      String
  evidence_id String?
  status      ReportStatus @default(OPEN)
  created_at  DateTime     @default(now())
}

// --- АУКЦИОНЫ ---

model Auction {
  id      Int           @id @default(autoincrement())
  title   String        @default("ГРАН-ПРИ [ЛОКАЦИЯ]")
  status  AuctionStatus @default(CREATED)
  race_id Int?          @unique
  race    Race?         @relation(fields: [race_id], references: [id])

  start_at     DateTime
  end_at       DateTime
  min_bid_step Int      @default(5)

  slots      AuctionSlot[]
  bids       AuctionBid[]
  created_at DateTime      @default(now())
}

model AuctionSlot {
  id         Int      @id @default(autoincrement())
  auction_id Int
  auction    Auction  @relation(fields: [auction_id], references: [id], onDelete: Cascade)
  number     Int // 1-16
  type       SlotType @default(CLOSED)

  winner_id Int?
  winner    User? @relation(fields: [winner_id], references: [id])

  @@unique([auction_id, number])
}

model AuctionBid {
  id          Int      @id @default(autoincrement())
  auction_id  Int
  auction     Auction  @relation(fields: [auction_id], references: [id], onDelete: Cascade)
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id])
  is_active   Boolean  @default(true)
  slot_number Int
  amount      Int
  created_at  DateTime @default(now())

  @@index([auction_id, slot_number, amount])
}

model RaceBet {
  id Int @id @default(autoincrement())

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  race_id Int
  race    Race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  target_acc_id  Int
  target_account GameAccount @relation(fields: [target_acc_id], references: [id])

  amount BigInt

  is_win        Boolean?
  payout_amount BigInt?

  created_at DateTime @default(now())

  @@index([race_id, target_acc_id])
}
